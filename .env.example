# ─── Database ─────────────────────────────────────────────────────
POSTGRES_USER=aistudio
POSTGRES_PASSWORD=aistudio_secret_change_in_prod
POSTGRES_DB=aistudio

# ─── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret_change_in_prod

# ─── Security ─────────────────────────────────────────────────────
SECRET_KEY=supersecretjwtkey_CHANGE_THIS_IN_PRODUCTION_minimum32chars
ENCRYPTION_KEY=encryptionkey32bytes_CHANGE_THIS_minimum32chars

# ─── ChromaDB ─────────────────────────────────────────────────────
CHROMA_AUTH_TOKEN=chromadb_secret_token

# ─── Claude / Anthropic (PRIMARY) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Groq LLM (legacy fallback) ──────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# ─── App ──────────────────────────────────────────────────────────
ENVIRONMENT=production
NEXT_PUBLIC_API_URL=http://localhost:8000
PORT=8000
ALLOWED_ORIGINS=https://your-frontend.pages.dev,http://localhost:3000
